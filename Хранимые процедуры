create or replace procedure add_product( 
    p_id int,
    p_cat_id int,
    p_name varchar,
    p_price numeric,
    p_stock int)
language plpgsql
as $$
begin
-- 1. вставляем данные в таблицу
insert into products(product_id, category_id, product_name, price, stock_quantity)
values(p_id, p_cat_id, p_name, p_price, p_stock);
-- 2. логируем действие в консоль
-- в raise notice используем % как заполнители для переменных
raise notice 'товар "%" (id: %) успешно добавлен в категорию %', p_name, p_id, p_cat_id;
end;
$$;
