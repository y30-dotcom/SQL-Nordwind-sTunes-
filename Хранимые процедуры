create or replace procedure update_stock(p_id int, p_change int)
language plpgsql
as $$
begin
    update products
    set stock_quantity = stock_quantity + p_change
    where product_id = p_id; -- проверяем, затронул ли update хоть одну строку if not found then raise exception 'товар с id % не найден!', p_id; end if; end; $$;`
вызов:
call update_stock(4, -2);

