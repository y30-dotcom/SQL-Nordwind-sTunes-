-- Сколько счетов превышают среднюю сумму счетов, выставленных в 2010 году?
SELECT count(*)
from invoices
where i.Total > (
	select avg(total)
	from invoices
	where InvoiceDate between '2010-01-01' and '2010-12-31')

-- Какие клиенты получили эти счета? 	
SELECT distinct c.CustomerId, c.FirstName, c.LastName
from customers c
join invoices i on c.CustomerId = i.CustomerId
where i.Total > (
	select avg(total)
	from invoices
	where InvoiceDate between '2010-01-01' and '2010-12-31')
	


-- Кто входит в десятку лучших клиентов с точки зрения совершенных ими покупок?
select c.FirstName ||" "|| c.LastName as Name, sum(i.Total), avg(i.Total), c.Country, count(i.InvoiceId )
from customers c
inner join invoices i  on i.CustomerId = c.CustomerId
group by c.CustomerId
order by sum(i.Total) desc
limit 10

-- Каковы средние годовые продажи клиентам из США согласно
-- имеющимся данным за все годы?
select c.FirstName ||" "|| c.LastName as Name,
SUM(i.Total) / COUNT(DISTINCT strftime('%Y', i.InvoiceDate)) AS avg_annual_sales
from invoices i
inner join customers c on i.CustomerId = c.CustomerId
WHERE c.Country = 'USA'
group by c.CustomerId


-- отдел обслуживания клиентов sTunes хочет поощрить сотрудников, 
-- которым удалось совершить десять самых лучших продаж
select e.FirstName, e.LastName, e.EmployeeId, 
c.FirstName, c.LastName, c.SupportRepId, 
i.CustomerId, i.Total, 
case 
	when total > 25 then 'the best'
	else 'noob'
end rating
from invoices i
inner join customers c on i.CustomerId = c.CustomerId 	-- одна соединяет счета и клиентов
inner join employees e on c.SupportRepId  = e.EmployeeId   	--  а другая соединяет и счета, и клиентов с сотрудниками
order by i.Total desc

CREATE VIEW V_inv_cus_emp AS
SELECT
i.InvoiceId, i.InvoiceDate, i.Total, i.CustomerId, c.FirstName, c.LastName, c.SupportRepId, e.EmployeeId, e.LastName, e.FirstName, e.Title
FROM
invoices AS i
INNER JOIN
customers AS c
ON
i.CustomerId = c.CustomerId
INNER JOIN
employees AS e
ON
e.EmployeeId = c.SupportRepId
ORDER BY
InvoiceDate

create view  V_CityAvgVsGlobalAvg as
SELECT
BillingCity, AVG(Total) AS [City Average],
(select * from V_GlobalAverage vga) AS [Global Average]
FROM
invoices
GROUP BY
BillingCity
ORDER BY
BillingCity
--получить список исполнителей, у которых нет альбома
select  ar.ArtistId AS [ArtistId From Artists Table],  
al.ArtistId AS [ArtistId From Albums Table],  
ar.Name AS [Artist Name],  
al.Title AS [Album Title] 
from artists ar 
left join albums al on ar.ArtistID = al.ArtistID
where al.ArtistId is null

-- Создайте внутреннее соединение между таблицами albums и tracks
-- и отобразите названия альбомов и названия треков в едином наборе результатов.
select  t.TrackId,    t.Composer,    t.Name,    al.AlbumId,    al.Title 
from tracks t
left join albums al on t.AlbumId = al.AlbumId 
where Composer is null

