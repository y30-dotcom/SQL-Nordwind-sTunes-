-- Кто входит в десятку лучших клиентов с точки зрения совершенных ими покупок?
select c.FirstName ||" "|| c.LastName as Name, sum(i.Total), avg(i.Total), c.Country, count(i.InvoiceId )
from customers c
inner join invoices i  on i.CustomerId = c.CustomerId
group by c.CustomerId
order by sum(i.Total) desc
limit 10


-- компания sTunes попросила нас собрать данные обо всех счетах,
-- сумма которых меньше этого среднего значения.
SELECT    InvoiceDate,    BillingAddress,    BillingCity,    Total
FROM    invoices
where Total <
		(SELECT AVG(Total)
		from invoices)
order by Total

-- компании sTunes нам надо узнать показатели продаж в каждом отдельном городе
-- и сравнить их со средними мировыми продажами?		
select BillingCity, round(avg(Total),2) as [city average],
	(select round(avg(Total),2)
	from invoices) as [global average]
from invoices
group by BillingCity
order by BillingCity

-- нас попросили найти самые большие продажи за весь период сбора данных (2009–2012 гг.)
-- и проверить, имеются ли какие-либо итоговые суммы счетов
-- за последний отчетный год (2013 г.), превышающие это значение.
select max(total)
from invoices i
where i.InvoiceDate < '2013-01-01'
-- заключим в круглые скобки
SELECT    InvoiceDate,    BillingCity,    Total
FROM    invoices
where InvoiceDate >= '2013-01-01' and total >
	(select max(total)
	from invoices i
	where i.InvoiceDate < '2013-01-01')

-- Сколько счетов, значения которых превышали среднюю сумму счета,
-- было зарегистрировано 1 января 2010 года или ранее?
SELECT    count(*)
FROM    invoices
where InvoiceDate <= '2010-01-01' and total >
	(select avg(total)
	from invoices i
	where i.InvoiceDate <= '2010-01-01')
	
