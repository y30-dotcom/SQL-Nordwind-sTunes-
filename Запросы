- Чтобы узнать возраст сотрудников, вычислим разницу во времени между 
-- датой рождения каждого сотрудника и текущей датой. 
-- Текущую дату можно получить, используя функцию NOW.
select LastName, FirstName,
strftime('%Y-%m-%d', Birthdate) AS [Birthday No Timecode],
strftime('%Y-%m-%d', 'now') as cont,
strftime('%Y-%m-%d', 'now') - strftime('%Y-%m-%d', Birthdate) as age 
from employees
order by age



