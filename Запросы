-- Используйте функцию SUBSTR(X, Y), возвращающую  только последние четыре цифры почтового индекса 
-- (там, где они есть) с псевдонимом ZIP + 4 Code.
select FirstName, 
substr(PostalCode,7) as 'ZIP + 4 Code',
substr(PostalCode,1,5) as 'ZIP +',
upper(FirstName),
lower(LastName),
upper(FirstName) || ' ' || upper(LastName) as FullName
from customers 
where Country = 'USA'

-- Компания sTunes отмечает дни рождения сотрудников первого числа каждого месяца. 
-- Создайте для отдела кадров таблицу, отображающую имена сотрудников, 
-- дни рождения и день празднования.
select LastName, FirstName,
strftime('%Y-%m-%d', Birthdate) as Birthday,
strftime('%m-%d',Birthdate,'start of month') || ' ' || FirstName as Celebrate
from employees

-- Отдел кадров компании sTunes сообщил нам, что возраст сотрудников 
-- это тема весьма деликатная. Перепишите этот запрос, 
-- чтобы в результате получить количество лет работы каждого сотрудника в компании. 
-- Какой сотрудник проработал в компании дольше всех?
select FirstName, LastName,
strftime('%Y-%m-%d',HireDate) as 'get a job',
strftime('%Y-%m-%d', 'now') - strftime('%Y-%m-%d',HireDate) as working
from employees
order by working desc

